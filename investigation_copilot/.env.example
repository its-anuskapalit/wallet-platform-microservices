# Required for embeddings + synthesis (same key as chatbot_service)
# If empty, the service also loads ..\chatbot_service\.env automatically (same GEMINI_API_KEY).
GEMINI_API_KEY=

# Text generation model (free tier has low RPM per model; try gemini-2.0-flash or gemini-1.5-flash if you hit 429).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: seconds to wait after the planner before RAG + synthesis (helps stay under ~5 RPM free tier).
# GEMINI_INTER_CALL_DELAY_SEC=13

# Speed (study / demo): skip LLM planner — only one Gemini call (synthesis). Heuristics pick tools.
# INVESTIGATION_FAST=1
# Skip per-request RAG (no KB snippets in prompt; no query embedding).
# INVESTIGATION_SKIP_RAG=1
# Skip embedding all KB files at startup (faster boot; no [KB] unless you turn RAG back on).
# INVESTIGATION_SKIP_RAG_INDEX=1

# Smaller prompt to Gemini = faster (default 20000 chars of live JSON).
# INVESTIGATION_TOOL_JSON_MAX_CHARS=12000

# Shorter answers, faster generation (e.g. 512 or 1024).
# GEMINI_MAX_OUTPUT_TOKENS=1024

# Read-only calls to your existing API Gateway (do not change microservices)
GATEWAY_BASE_URL=http://localhost:5000

# If the browser calls Angular from a LAN URL (e.g. http://192.168.x.x:4200), set CORS allow-all:
# INVESTIGATION_CORS_ALLOW_ALL=1

# Stop /api/investigate after N seconds (Swagger shows 504 instead of spinning). Default 600; 0 = no limit.
# INVESTIGATION_REQUEST_TIMEOUT_SEC=900

# Fewer retries on 429 (faster failure in dev). Default 8.
# GEMINI_MAX_RETRIES=3
