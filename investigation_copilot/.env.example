# =============================================================================
# Quota & rate limits (HTTP 429 / RESOURCE_EXHAUSTED)
# =============================================================================
# Free-tier Gemini limits are per model and per day. If you see quota errors:
# - Enable billing on the Google AI / Cloud project for your API key, or wait for the daily reset.
# - Try a different GEMINI_MODEL (each model has its own quota bucket).
# - INVESTIGATION_FAST=1 — skips the planner LLM call; only one generate_content per request (half the calls).
# - GEMINI_INTER_CALL_DELAY_SEC — pause between planner and synthesis to ease per-minute bursts (e.g. 1–13).
# - Lower INVESTIGATION_TOOL_JSON_MAX_CHARS to reduce input tokens.
# - GEMINI_MAX_RETRIES — fewer retries fails faster in dev when quota is zero (see gemini_retry.py).
# =============================================================================

# Required for embeddings + synthesis (same key as chatbot_service)
# If empty, the service also loads ..\chatbot_service\.env automatically (same GEMINI_API_KEY).
GEMINI_API_KEY=

# Text generation model (default in code: gemini-2.0-flash). Free tier: low RPM per model; switch if you hit 429.
# Examples: gemini-2.0-flash, gemini-2.5-flash (availability depends on your key / region).
# GEMINI_MODEL=gemini-2.5-flash

# Optional: seconds to wait after the planner before RAG + synthesis (helps stay under per-minute limits).
# GEMINI_INTER_CALL_DELAY_SEC=13

# When Gemini hits quota, return HTTP 200 with live gateway JSON instead of 429 (default on).
# INVESTIGATION_LLM_FALLBACK_ON_QUOTA=0

# Speed / quota: skip LLM planner — only one Gemini call (synthesis). Heuristics + keywords pick tools.
# INVESTIGATION_FAST=1
# Skip per-request RAG (no KB snippets in prompt; no query embedding).
# INVESTIGATION_SKIP_RAG=1
# Skip embedding all KB files at startup (faster boot; no [KB] unless you turn RAG back on).
# INVESTIGATION_SKIP_RAG_INDEX=1

# Smaller prompt to Gemini = faster (default 20000 chars of live JSON).
# INVESTIGATION_TOOL_JSON_MAX_CHARS=12000

# Shorter answers, faster generation (e.g. 512 or 1024).
# GEMINI_MAX_OUTPUT_TOKENS=1024

# Read-only calls to your existing API Gateway (do not change microservices)
GATEWAY_BASE_URL=http://localhost:5000

# If the browser calls Angular from a LAN URL (e.g. http://192.168.x.x:4200), set CORS allow-all:
# INVESTIGATION_CORS_ALLOW_ALL=1

# Stop /api/investigate after N seconds (Swagger shows 504 instead of spinning). Default 600; 0 = no limit.
# INVESTIGATION_REQUEST_TIMEOUT_SEC=900

# Fewer retries on 429 (faster failure in dev). Default 8.
# GEMINI_MAX_RETRIES=3
